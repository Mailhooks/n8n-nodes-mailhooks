{
  "name": "n8n-nodes-mailhooks",
  "version": "1.0.1",
  "description": "n8n community node for Mailhooks - receive, filter, and process emails in your n8n workflows",
  "license": "MIT",
  "homepage": "https://github.com/Mailhooks/n8n-nodes-mailhooks#readme",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "mailhooks",
    "email",
    "webhook",
    "email-automation",
    "inbound-email"
  ],
  "author": {
    "name": "Adam Hancock",
    "email": "adam@assurix.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mailhooks/n8n-nodes-mailhooks.git"
  },
  "bugs": {
    "url": "https://github.com/Mailhooks/n8n-nodes-mailhooks/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/MailhooksApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Mailhooks/Mailhooks.node.js",
      "dist/nodes/MailhooksTrigger/MailhooksTrigger.node.js",
      "dist/nodes/MailhooksPollingTrigger/MailhooksPollingTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": ">=0.23.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "eslint": "9.32.0",
    "fast-glob": "^3.3.3",
    "jest": "^30.3.0",
    "prettier": "3.6.2",
    "release-it": "^20.0.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
